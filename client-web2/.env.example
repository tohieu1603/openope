# Operis API URL (remote server for auth, billing, chat routing)
VITE_API_BASE_URL=http://localhost:3025/api

# Gateway URL (optional, for direct gateway mode - leave empty for same origin)
# VITE_GATEWAY_URL=

# Gateway Token (for authenticating WS connection to gateway)
VITE_GATEWAY_TOKEN=062b504ca89acfab38e7f0318d0d2d1f19a83b03fe9619f1

# Gateway WebSocket URL (for receiving tool events from the gateway)
VITE_GATEWAY_WS=ws://127.0.0.1:3000/
